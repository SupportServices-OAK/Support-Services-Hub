<script>
(function() {
var sgGoals = [
  { text: '"I will save $200 by September by setting aside $25/week."', smart: true },
  { text: '"I want to be successful."', smart: false },
  { text: '"I\'ll write my scholarship essay by Monday and review it with my mentor."', smart: true },
  { text: '"I want to stop being lazy."', smart: false },
  { text: '"I plan to talk to 2 adults I trust this week about internship opportunities."', smart: true },
  { text: '"I\'ll try not to argue with my brother anymore."', smart: false },
  { text: '"I will read one book a month from my college prep list and journal 5 takeaways."', smart: true },
  { text: '"I want to start waking up earlier."', smart: false }
];

var sgStates = {};
var sgSelected = null;

function sgRender() {
  var unsorted = document.getElementById('sg-unsorted');
  var vague = document.getElementById('sg-vague-zone');
  var smart = document.getElementById('sg-smart-zone');
  if (!unsorted) return;
  unsorted.innerHTML = ''; vague.innerHTML = ''; smart.innerHTML = '';
  sgGoals.forEach(function(g, i) {
    var pill = document.createElement('div');
    pill.className = 'sg-goal-pill';
    var state = sgStates[i];
    if (state === 'smart') pill.classList.add('placed-smart');
    if (state === 'vague') pill.classList.add('placed-vague');
    pill.textContent = g.text;
    pill.dataset.idx = i;
    pill.onclick = function() { sgHandleClick(i); };
    if (!state) unsorted.appendChild(pill);
    else if (state === 'smart') smart.appendChild(pill);
    else vague.appendChild(pill);
  });
  document.getElementById('sg-score').classList.remove('show','perfect','good','retry');
}

function sgHandleClick(i) {
  var state = sgStates[i];
  // cycle: unsorted → smart → vague → unsorted
  if (!state) sgStates[i] = 'smart';
  else if (state === 'smart') sgStates[i] = 'vague';
  else sgStates[i] = null;
  sgRender();
}

function sgCheckSort() {
  var unsortedCount = 0, correct = 0;
  sgGoals.forEach(function(g, i) {
    if (!sgStates[i]) { unsortedCount++; return; }
    if ((sgStates[i] === 'smart') === g.smart) correct++;
  });
  var scoreEl = document.getElementById('sg-score');
  scoreEl.classList.remove('perfect','good','retry');
  if (unsortedCount > 0) {
    scoreEl.textContent = 'Sort all ' + unsortedCount + ' remaining goal(s) first!';
    scoreEl.classList.add('show','retry');
    return;
  }
  var total = sgGoals.length;
  if (correct === total) {
    scoreEl.textContent = '🔥 Perfect — ' + correct + '/' + total + '! You know your S.M.A.R.T. goals!';
    scoreEl.classList.add('show','perfect');
  } else if (correct >= Math.ceil(total * 0.6)) {
    scoreEl.textContent = '✓ ' + correct + '/' + total + ' correct — solid! Review the ones you missed.';
    scoreEl.classList.add('show','good');
  } else {
    scoreEl.textContent = correct + '/' + total + ' correct — review the S.M.A.R.T. criteria and try again!';
    scoreEl.classList.add('show','retry');
  }
}

function sgResetSort() { sgGoals.forEach(function(_,i){sgStates[i]=null;}); sgRender(); }

function sendSmartGoal() {
  var fields = ['s','m','a','r','t'];
  var email = document.getElementById('smart-email');
  var status = document.getElementById('smart-email-status');
  if (!email || !email.value) {
    if (status) { status.textContent = 'Please enter your email address.'; status.style.color = '#ffe000'; }
    return;
  }
  var body = 'My S.M.A.R.T. Goal%0A%0A';
  var labels = {s:'Specific',m:'Measurable',a:'Actionable',r:'Relevant',t:'Timebound'};
  fields.forEach(function(k) {
    var el = document.getElementById('smart-' + k);
    body += labels[k] + ': ' + encodeURIComponent(el ? el.value || '(blank)' : '') + '%0A';
  });
  window.location.href = 'mailto:' + encodeURIComponent(email.value) + '?subject=My%20S.M.A.R.T.%20Goal%20%E2%80%94%20Hidden%20Genius%20Project&body=' + body;
  if (status) { status.textContent = '✓ Opening your email client!'; status.style.color = '#ffe000'; }
}

// Init
sgGoals.forEach(function(_,i){sgStates[i]=null;});
sgRender();

window.sendSmartGoal = sendSmartGoal;
window.sgCheckSort = sgCheckSort;
window.sgResetSort = sgResetSort;

})();
</script>
