<script>
(function(){

  // ── Filter state
  const filters = { mode: 'all', cost: 'all' };
  let audience = 'all';

  // ── Audience toggle
  function setAudience(val) {
    audience = val;
    ['all','genius','parent'].forEach(a => {
      document.getElementById('aud-'+a).classList.toggle('active', a === val);
    });
    const pb = document.getElementById('parentBox');
    pb.style.display = (val === 'genius') ? 'none' : '';
  }

  // ── Filter buttons
  function setFilter(type, val, btn) {
    filters[type] = val;
    document.querySelectorAll(`[data-filter="${type}"]`).forEach(b => {
      b.classList.toggle('active', b.dataset.val === val);
    });
    filterCards();
  }

  // ── Main filter/search function
  function filterCards() {
    const query = document.getElementById('searchInput').value.toLowerCase().trim();
    const cards = document.querySelectorAll('.prog-card');
    let visible = 0;

    cards.forEach(card => {
      const tags    = (card.dataset.tags || '').toLowerCase();
      const name    = card.querySelector('.card-name')?.textContent.toLowerCase() || '';
      const org     = card.querySelector('.card-org')?.textContent.toLowerCase() || '';
      const desc    = card.querySelector('.card-desc')?.textContent.toLowerCase() || '';
      const meta    = card.querySelector('.card-meta')?.textContent.toLowerCase() || '';
      const haystack = tags + ' ' + name + ' ' + org + ' ' + desc + ' ' + meta;

      const matchSearch = !query || haystack.includes(query);
      const matchMode   = filters.mode === 'all' || card.dataset.mode === filters.mode ||
                          (filters.mode !== 'all' && card.dataset.mode === 'both');
      const matchCost   = filters.cost === 'all' || card.dataset.cost === filters.cost;

      const show = matchSearch && matchMode && matchCost;
      card.classList.toggle('hidden', !show);
      if (show) visible++;
    });

    document.getElementById('resultsCount').textContent = `${visible} program${visible !== 1 ? 's' : ''}`;

    // Section-level counts + hide empty sections
    ['1','2','3'].forEach(i => {
      const grid = document.getElementById('grid'+i);
      if (!grid) return;
      const sectionVisible = grid.querySelectorAll('.prog-card:not(.hidden)').length;
      const countEl = document.getElementById('count'+i);
      if (countEl) countEl.textContent = sectionVisible > 0 ? sectionVisible + ' shown' : '';
      const section = document.getElementById('section'+i);
      if (section) section.style.display = sectionVisible === 0 ? 'none' : '';
    });

    const noResults = document.getElementById('noResults');
    noResults.classList.toggle('show', visible === 0);
  }

  // ── Expand/collapse card desc
  function toggleDesc(id, btn) {
    const el = document.getElementById(id);
    const expanded = el.classList.toggle('expanded');
    btn.textContent = expanded ? 'Show less ↑' : 'Read more ↓';
  }

  // ── Init section counts
  filterCards();

window.setAudience = setAudience;
window.setFilter = setFilter;
window.filterCards = filterCards;
window.toggleDesc = toggleDesc;
})();
</script>

