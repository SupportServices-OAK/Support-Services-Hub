.ticker-inner span { font-family: 'DINNextLT', monospace; font-size: 9px; font-weight: 500; letter-spacing: 2.5px; text-transform: uppercase; color: var(--black); padding: 0 36px; }
@keyframes ticker { from { transform: translateX(0); } to { transform: translateX(-50%); } }

nav { background: var(--black); display: flex; align-items: center; justify-content: space-between; padding: 1.1rem 2.5rem; border-bottom: 1px solid var(--border); position: sticky; top: 0; z-index: 100; }
