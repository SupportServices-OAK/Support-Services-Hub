function runMatch() {
  var gpa = document.getElementById('gpa').value;
  var major = document.getElementById('major').value;
  var budget = document.getElementById('budget').value;
  var size = document.getElementById('size').value;
  var prox = document.getElementById('prox').value;
  var weather = document.getElementById('weather').value;
  var pBtns = document.querySelectorAll('.pbtn.sel');
  var priorities = [];
  pBtns.forEach(function(b) { priorities.push(b.getAttribute('data-p')); });

  var gpaMap = {'4plus':4.0,'3.5':3.7,'3.0':3.25,'2.5':2.75,'2.0':2.25};
  var gpaV = gpaMap[gpa] || 3.0;

  var scored = colleges.map(function(c) {
    var s = 0;
    if (gpaV >= c.gpaMin) s += 20;
    if (!major || major === 'undecided' || c.majors.indexOf(major) !== -1) s += 15;
    if (budget === 'low' && c.afford === 'low') s += 15;
    else if (budget === 'mid' && (c.afford === 'low' || c.afford === 'mid')) s += 10;
    else if (budget) s += 5;
    if (!size || c.size === size) s += 8;
    if (!prox || prox === 'ca') s += 8;
    else if (c.prox === prox) s += 16;
    if (!weather || c.weather === weather) s += 8;
    priorities.forEach(function(p) {
      if (p === 'blackcomm' && c.blackComm >= 4) s += 14;
      if (p === 'safety' && c.blackSafe >= 4) s += 14;
      if (p === 'progressive' && c.pol === 'progressive') s += 8;
      if (p === 'sports' && c.hasSports) s += 12;
      if (p === 'grad' && c.hasGrad) s += 8;
      if (p === 'city' && c.urban) s += 8;
      if (p === 'aid' && c.finAid >= 4) s += 14;
      if (p === 'diverse' && c.blackComm >= 4) s += 8;
      if (p === 'research' && c.hasGrad) s += 8;
      if (p === 'small' && c.size === 'small') s += 10;
      if (p === 'internship' && c.urban) s += 8;
      if (p === 'social' && c.urban) s += 6;
    });
    return Object.assign({}, c, { score: s });
  });

  var filtered = scored.filter(function(c) { return gpaV >= c.gpaMin; });
  filtered.sort(function(a, b) { return b.score - a.score; });
  var top = filtered.slice(0, 9);

  var h = '<div class="match-head"><h3>Your Top Matches</h3><p>' + top.length + ' colleges matched — sorted by fit score</p></div><div class="ccards">';
  top.forEach(function(c) {
    var pct = Math.min(99, Math.round(40 + (c.score / 2)));
    h += '<div class="ccard">';
    h += '<div class="ccard-top">';
    h += '<div class="cc-score">' + pct + '% match</div>';
    h += '<div class="cc-sys">' + c.sys + '</div>';
    h += '<div class="cc-name">' + c.name + '</div>';
    h += '<div class="cc-loc">📍 ' + c.loc + '</div>';
    h += '</div><div class="ccard-body">';
    h += '<div class="cc-tags">';
    c.tags.forEach(function(t) { h += '<span class="cctag ' + t[1] + '">' + t[0] + '</span>'; });
    h += '</div><div class="cc-facts">';
    h += '<div><div class="ccf-l">Acceptance</div><div class="ccf-v">' + c.facts.acc + '</div></div>';
    h += '<div><div class="ccf-l">Avg Aid</div><div class="ccf-v">' + c.facts.aid + '</div></div>';
    h += '<div><div class="ccf-l">Black Enrollment</div><div class="ccf-v">' + c.facts.black + '</div></div>';
    h += '<div><div class="ccf-l">Tuition</div><div class="ccf-v">' + c.tuition + '</div></div>';
    h += '</div></div></div>';
  });
  h += '</div>';

  var el = document.getElementById('match-results');
  el.innerHTML = h;
  el.classList.add('show');
  el.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
}

