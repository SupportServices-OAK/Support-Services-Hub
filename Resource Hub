<script>
(function() {
  'use strict';

  function showHome() {
    document.querySelectorAll('.page-panel').forEach(function(p) {
      p.classList.remove('page-visible');
    });
    setTimeout(function() {
      document.getElementById('hub-home').style.display = 'block';
      document.querySelectorAll('.page-panel').forEach(function(p) {
        p.style.display = 'none';
        p.classList.remove('active');
      });
    }, 200);
    document.querySelectorAll('.hnb').forEach(function(b) { b.classList.remove('active'); });
    window.scrollTo(0, 0);
  }

  function showPage(id) {
    document.getElementById('hub-home').style.display = 'none';
    document.querySelectorAll('.page-panel').forEach(function(p) {
      p.style.display = 'none';
      p.classList.remove('active');
      p.classList.remove('page-visible');
    });
    var panel = document.getElementById('page-' + id);
    if (panel) {
      panel.style.display = 'block';
      panel.classList.add('active');
      // Trigger transition after paint
      requestAnimationFrame(function() {
        requestAnimationFrame(function() {
          panel.classList.add('page-visible');
        });
      });
    }
    document.querySelectorAll('.hnb').forEach(function(b) { b.classList.remove('active'); });
    window.scrollTo(0, 0);
  }

  function hubFilter(cat, btn) {
    document.querySelectorAll('.fb').forEach(function(b) { b.classList.remove('active'); });
    btn.classList.add('active');
    document.querySelectorAll('.rc').forEach(function(card) {
      var cats = card.getAttribute('data-cat') || '';
      card.classList.toggle('hid', cat !== 'all' && !cats.includes(cat));
    });
  }

  function filterAndScroll(cat) {
    document.querySelectorAll('.fb').forEach(function(btn) {
      var oc = btn.getAttribute('onclick') || '';
      if (oc.indexOf("'" + cat + "'") !== -1) {
        hubFilter(cat, btn);
      }
    });
    setTimeout(function() {
      var el = document.getElementById('hub-resources');
      if (el) el.scrollIntoView({ behavior: 'smooth' });
    }, 100);
  }

  // Expose to global for onclick handlers
  window.showHome = showHome;
  window.showPage = showPage;
  window.hubFilter = hubFilter;
  window.filterAndScroll = filterAndScroll;

  // Scroll-reveal
  var observer = new IntersectionObserver(function(entries) {
    entries.forEach(function(e) {
      if (e.isIntersecting) {
        e.target.style.opacity = '1';
        e.target.style.transform = 'translateY(0)';
      }
    });
  }, { threshold: 0.08 });

  document.querySelectorAll('.rc, .wc').forEach(function(el) {
    el.style.opacity = '0';
    el.style.transform = 'translateY(14px)';
    el.style.transition = 'opacity .45s ease, transform .45s ease, border-color .25s, box-shadow .25s';
    observer.observe(el);
  });

})();
</script>

