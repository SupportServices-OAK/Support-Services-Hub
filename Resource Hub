/* ===================== HUB SHELL ===================== */
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{--gold:#ffe000;--black:#0A0A0A;--near:#141414;--white:#fff;--border:rgba(255,255,255,0.08)}
html{scroll-behavior:smooth}
body{font-family:'Gotham',sans-serif;background:var(--black);color:var(--white);min-height:100vh;overflow-x:hidden}

/* TOP NAV */
.hub-nav{background:var(--black);display:flex;align-items:center;justify-content:space-between;padding:.85rem 2rem;border-bottom:1px solid var(--border);position:sticky;top:0;z-index:9999}
.hub-brand{display:flex;align-items:center;gap:11px;cursor:pointer;border:none;background:none;color:inherit}
.hub-logo{display:flex;align-items:center;padding:2px 0}
.hub-name{font-family:'Gotham',sans-serif;font-weight:800;font-size:16px;letter-spacing:1.5px;color:var(--white)}
.hub-name span{color:var(--gold)}
.hub-links{display:flex;gap:.35rem;flex-wrap:wrap}
.hnb{font-family:'DINNextLT',sans-serif;font-size:7.5px;letter-spacing:1.5px;text-transform:uppercase;padding:5px 10px;border-radius:20px;border:1px solid var(--border);background:transparent;color:rgba(255,255,255,.4);cursor:pointer;transition:all .2s;white-space:nowrap}
.hnb:hover{background:rgba(255,224,0,.08);color:var(--gold);border-color:rgba(255,224,0,.25)}
.hnb.active,.hnb:focus-visible{background:var(--gold);color:var(--black);border-color:var(--gold);outline:none}
.hnb-red{background:rgba(192,57,43,.12);color:#E87B6E;border-color:rgba(192,57,43,.3)}

/* TICKER */
.hub-logo-bar{background:var(--black);display:flex;align-items:center;justify-content:center;padding:16px 2rem;border-bottom:3px solid var(--gold)}

/* HOME */
.hub-hero{position:relative;min-height:80vh;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:5rem 2rem 4rem;overflow:hidden}
.hub-hero::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 80% 60% at 50% 40%,rgba(255,224,0,.07) 0%,transparent 70%),repeating-linear-gradient(0deg,transparent,transparent 60px,rgba(255,255,255,.015) 60px,rgba(255,255,255,.015) 61px),repeating-linear-gradient(90deg,transparent,transparent 60px,rgba(255,255,255,.015) 60px,rgba(255,255,255,.015) 61px);pointer-events:none}
.h-eyebrow{font-family:'DINNextLT',sans-serif;font-size:9px;letter-spacing:3px;text-transform:uppercase;color:var(--gold);margin-bottom:1.2rem;opacity:0;animation:fadeUp .6s .1s ease forwards}
.h-title{font-family:'Gotham',sans-serif;font-weight:800;font-size:clamp(4rem,12vw,9rem);line-height:.9;letter-spacing:2px;color:var(--white);opacity:0;animation:fadeUp .7s .2s ease forwards}
.h-title em{font-style:normal;color:var(--gold);display:block}
.h-sub{font-size:1rem;font-weight:300;color:rgba(255,255,255,.5);max-width:500px;line-height:1.7;margin:1.5rem auto 0;opacity:0;animation:fadeUp .7s .35s ease forwards}
@keyframes fadeUp{from{opacity:0;transform:translateY(18px)}to{opacity:1;transform:translateY(0)}}

/* WHO CARDS */
.hub-who{background:var(--near);padding:4rem 2rem;text-align:center;border-top:1px solid var(--border);border-bottom:1px solid var(--border)}
.sec-label{font-family:'DINNextLT',sans-serif;font-size:8px;letter-spacing:3px;text-transform:uppercase;color:var(--gold);margin-bottom:.6rem}
.hub-who h2{font-family:'Gotham',sans-serif;font-weight:800;font-size:clamp(2rem,5vw,3.5rem);letter-spacing:1.5px;margin-bottom:.4rem}
.hub-who>p{color:rgba(255,255,255,.4);font-size:.88rem;font-weight:300;margin-bottom:2.5rem}
.wc-grid{display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;max-width:880px;margin:0 auto}
.wc{flex:1;min-width:200px;max-width:260px;background:var(--black);border:1px solid var(--border);border-radius:8px;padding:1.8rem 1.4rem;cursor:pointer;text-align:center;transition:border-color .25s,transform .25s,box-shadow .25s;position:relative;overflow:hidden;border:none;color:var(--white)}
.wc::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:var(--gold);transform:scaleX(0);transition:transform .3s ease;transform-origin:left}
.wc:hover::before{transform:scaleX(1)}
.wc:hover{border-color:rgba(255,224,0,.3);transform:translateY(-4px);box-shadow:0 16px 48px rgba(0,0,0,.5)}
.wc-icon{font-size:2rem;margin-bottom:.8rem}
.wc h3{font-family:'Gotham',sans-serif;font-weight:800;font-size:1.5rem;letter-spacing:1px;color:var(--gold);margin-bottom:.4rem}
.wc p{font-size:.78rem;color:rgba(255,255,255,.4);line-height:1.6}
/* re-apply border since we used border:none for button reset */
.wc{border:1px solid var(--border)!important}
.wc:hover{border-color:rgba(255,224,0,.3)!important}

/* EMERGENCY BANNER */
.hub-banner-wrap{padding:3rem 2rem 0;max-width:1160px;margin:0 auto}
.hub-ebanner{background:var(--gold);border-radius:10px;padding:2.5rem 3rem;display:flex;align-items:center;justify-content:space-between;gap:1.5rem;flex-wrap:wrap}
.hub-ebanner .hub-who h3{font-family:'Gotham',sans-serif;font-weight:800;font-size:2rem;letter-spacing:1px;color:var(--gold);margin-bottom:.3rem}
.hub-ebanner p{color:rgba(0,0,0,.6);font-size:.85rem;max-width:460px}
.hub-ebanner-btn{display:inline-flex;align-items:center;background:var(--black);color:var(--gold);font-family:'Gotham',sans-serif;font-weight:700;font-size:.78rem;letter-spacing:1px;text-transform:uppercase;padding:.9rem 1.8rem;border-radius:4px;border:none;cursor:pointer;white-space:nowrap;transition:transform .2s,box-shadow .2s}
.hub-ebanner-btn:hover{transform:translateY(-2px);box-shadow:0 10px 30px rgba(0,0,0,.3)}

/* RESOURCE GRID */
.hub-grid-section{padding:4rem 2rem 5rem;max-width:1160px;margin:0 auto}
.hub-grid-section h2{font-family:'Gotham',sans-serif;font-weight:800;font-size:clamp(2rem,5vw,3.2rem);letter-spacing:1.5px;margin-bottom:.3rem}
.hub-grid-section>p{color:rgba(255,255,255,.35);font-size:.85rem;margin-bottom:2rem}
.filter-row{display:flex;gap:.4rem;flex-wrap:wrap;margin-bottom:2rem}
.fb{font-family:'DINNextLT',sans-serif;font-size:8.5px;letter-spacing:2px;text-transform:uppercase;padding:6px 14px;border-radius:20px;border:1px solid var(--border);background:transparent;color:rgba(255,255,255,.4);cursor:pointer;transition:all .2s}
.fb:hover,.fb.active{background:var(--gold);color:var(--black);border-color:var(--gold)}
.card-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:1rem}
.rc{background:var(--near);border:1px solid var(--border);border-radius:10px;padding:1.6rem;cursor:pointer;color:var(--white);display:flex;flex-direction:column;gap:.7rem;transition:all .25s;position:relative;overflow:hidden;text-align:left;width:100%}
.rc::after{content:'→';position:absolute;right:1.4rem;bottom:1.4rem;font-size:1rem;color:var(--gold);opacity:0;transition:opacity .2s,transform .2s;transform:translateX(-4px)}
.rc:hover::after{opacity:1;transform:translateX(0)}
.rc:hover{border-color:rgba(255,224,0,.25);transform:translateY(-3px);box-shadow:0 12px 40px rgba(0,0,0,.4)}
.rc.hid{display:none}
.ctag{display:inline-flex;font-family:'DINNextLT',sans-serif;font-size:7.5px;letter-spacing:2px;text-transform:uppercase;padding:3px 9px;border-radius:20px;width:fit-content}
.t-ac{background:rgba(27,95,168,.15);color:#5B9EDF;border:1px solid rgba(27,95,168,.25)}
.t-co{background:rgba(29,138,78,.15);color:#5EC98A;border:1px solid rgba(29,138,78,.25)}
.t-sk{background:rgba(107,63,160,.15);color:#B08FE0;border:1px solid rgba(107,63,160,.25)}
.t-su{background:rgba(192,57,43,.15);color:#E87B6E;border:1px solid rgba(192,57,43,.25)}
.t-cm{background:rgba(15,122,110,.15);color:#4CBFB3;border:1px solid rgba(15,122,110,.25)}
.rc-icon{font-size:1.5rem}
.rc-title{font-family:'Gotham',sans-serif;font-weight:800;font-size:1.35rem;letter-spacing:.8px;line-height:1.1}
.rc-desc{font-size:.8rem;color:rgba(255,255,255,.42);line-height:1.65;font-weight:300}
.rc-meta{margin-top:auto;padding-top:.7rem;border-top:1px solid var(--border);font-family:'DINNextLT',sans-serif;font-size:7.5px;letter-spacing:1.5px;text-transform:uppercase;color:rgba(255,255,255,.2)}

/* FOOTER */
.hub-footer{background:var(--black);border-top:1px solid var(--border);padding:2rem;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem;margin-top:3rem}
.hf-brand{font-family:'Gotham',sans-serif;font-weight:800;font-size:1rem;letter-spacing:1.5px;color:rgba(255,255,255,.4)}
.hf-brand span{color:var(--gold)}
.hf-copy{font-family:'DINNextLT',sans-serif;font-size:7.5px;letter-spacing:1px;color:rgba(255,255,255,.2)}

/* PAGE PANELS */
.page-panel{
  display:none;
  min-height:calc(100vh - 50px);
  opacity:0;
  transform:translateY(24px);
  transition:opacity .38s ease, transform .38s ease;
}
.page-panel.active{
  display:block;
}
.page-panel.page-visible{
  opacity:1;
  transform:translateY(0);
}

/* INNER NAV (sticky back bar inside each page) */
.page-inner-nav{background:var(--black);border-bottom:2px solid var(--gold);padding:.8rem 2rem;display:flex;align-items:center;gap:1rem;position:sticky;top:49px;z-index:9998}
.back-to-hub{font-family:'DINNextLT',sans-serif;font-size:8.5px;letter-spacing:2px;text-transform:uppercase;background:var(--gold);color:var(--black);border:none;padding:7px 14px;border-radius:4px;cursor:pointer;font-weight:700;transition:transform .15s;flex-shrink:0}
.back-to-hub:hover{transform:translateX(-2px)}
.page-breadcrumb{font-family:'DINNextLT',sans-serif;font-size:8.5px;letter-spacing:2px;text-transform:uppercase;color:rgba(255,255,255,.4)}

/* Fix stacking for success overlay in needs form */
#successOverlay{z-index:99999!important}

/* RESPONSIVE */
@media(max-width:700px){
  .hub-nav{padding:.8rem 1rem}
  .hub-links{display:none}
  .hub-hero,.hub-who,.hub-grid-section{padding-left:1.2rem;padding-right:1.2rem}
  .hub-banner-wrap{padding:2rem 1.2rem 0}
  .hub-ebanner{padding:1.8rem 1.5rem}
  .hub-footer{padding:1.5rem 1.2rem}
  .page-inner-nav{padding:.7rem 1rem;top:46px}
}


/* ─── GLOBAL: Prevent dark-on-dark text in page panels ─── */
.page-panel { color: #fff; background: #0a0a0a; }
/* ===================== EMBEDDED PAGE STYLES ===================== */

/* === AG === */

  :root {
    --hgp-yellow: #FFE000;
    --hgp-black: #FFFFFF;
    --hgp-white: #FFFFFF;
    --hgp-gray: #F5F5F5;
    --hgp-mid-gray: #E0E0E0;
    --hgp-dark-gray: #444444;
    --hgp-accent: #222222;
    --free-color: #2D7D46;
    --low-cost-color: #1A6B9A;
    --sliding-color: #7B3FA0;
    --app-color: #C45C00;
    --pdf-color: #B5171A;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'Gotham', sans-serif;
    background: var(--hgp-black);
    color: var(--hgp-white);
    line-height: 1.5;
  }

  /* ── HEADER ── */
  header {
    background: var(--hgp-yellow);
    color: var(--hgp-black);
    padding: 0;
    position: sticky;
    top: 0;
    z-index: 100;
    box-shadow: 0 4px 20px rgba(0,0,0,0.4);
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 32px;
    max-width: 1200px;
    margin: 0 auto;
  }
  .hgp-logo-area {
    display: flex;
    align-items: center;
    gap: 14px;
  }
  .logo-mark {
    width: 48px;
    height: 48px;
    background: var(--hgp-black);
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .logo-mark svg { width: 36px; height: 36px; }
  .org-name {
    font-family: 'DINNextLT', sans-serif;
    font-weight: 900;
    font-size: 1.1rem;
    line-height: 1.15;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }
  .org-name span { display: block; font-weight: 400; font-size: 0.75rem; letter-spacing: 0.12em; }
  .header-title {
    font-family: 'DINNextLT', sans-serif;
    font-weight: 800;
    font-size: 1.3rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    text-align: right;
  }
  .header-title small { display: block; font-weight: 500; font-size: 0.65rem; letter-spacing: 0.15em; }

  /* ── HERO ── */
  .hero {
    background: var(--hgp-black);
    border-bottom: 4px solid var(--hgp-yellow);
    padding: 64px 32px 52px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      -45deg,
      transparent,
      transparent 40px,
      rgba(255,224,0,0.03) 40px,
      rgba(255,224,0,0.03) 41px
    );
  }
  .hero-eyebrow {
    font-family: 'DINNextLT', sans-serif;
    font-weight: 600;
    font-size: 0.8rem;
    letter-spacing: 0.2em;
    color: var(--hgp-yellow);
    text-transform: uppercase;
    margin-bottom: 14px;
  }
  .hero h1 {
    font-family: 'DINNextLT', sans-serif;
    font-weight: 900;
    font-size: clamp(3rem, 6vw, 5.5rem);
    text-transform: uppercase;
    line-height: 0.9;
    letter-spacing: -0.01em;
    color: var(--hgp-white);
    margin-bottom: 8px;
  }
  .hero h1 em {
    font-style: normal;
    color: var(--hgp-yellow);
    display: block;
  }
  .hero-sub {
    font-family: 'Gotham', sans-serif;
    font-weight: 300;
    font-size: 1.05rem;
    color: rgba(255,255,255,0.7);
    max-width: 560px;
    margin: 20px auto 0;
    line-height: 1.6;
  }

  /* ── LEGEND ── */
  .legend-bar {
    background: #1A1A1A;
    border-top: 1px solid #333;
    border-bottom: 1px solid #333;
    padding: 16px 32px;
  }
  .legend-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-wrap: wrap;
    gap: 20px;
    align-items: center;
  }
  .legend-label {
    font-family: 'DINNextLT', sans-serif;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #888;
    margin-right: 8px;
  }
  .legend-items {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }
  .badge {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 3px 9px;
    border-radius: 3px;
    font-family: 'DINNextLT', sans-serif;
    font-weight: 700;
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    white-space: nowrap;
  }
  .badge-free { background: rgba(45,125,70,0.2); color: #5DC986; border: 1px solid rgba(45,125,70,0.5); }
  .badge-lowcost { background: rgba(26,107,154,0.2); color: #6BC5F5; border: 1px solid rgba(26,107,154,0.5); }
  .badge-sliding { background: rgba(123,63,160,0.2); color: #C794E8; border: 1px solid rgba(123,63,160,0.5); }
  .badge-app { background: rgba(196,92,0,0.2); color: #FFAA66; border: 1px solid rgba(196,92,0,0.5); }
  .badge-pdf { background: rgba(181,23,26,0.2); color: #FF8A8C; border: 1px solid rgba(181,23,26,0.5); }
  .badge-bay { background: rgba(255,224,0,0.15); color: var(--hgp-yellow); border: 1px solid rgba(255,224,0,0.4); }
  .badge-virtual { background: rgba(255,255,255,0.07); color: #CCC; border: 1px solid rgba(255,255,255,0.2); }

  /* ── NAV TABS ── */
  .nav-section {
    background: #161616;
    border-bottom: 1px solid #2A2A2A;
    padding: 0 32px;
    position: sticky;
    top: 76px;
    z-index: 90;
    overflow-x: auto;
  }
  .nav-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    gap: 0;
  }
  .nav-tab {
    font-family: 'DINNextLT', sans-serif;
    font-weight: 700;
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #777;
    padding: 14px 18px 12px;
    border-bottom: 3px solid transparent;
    cursor: pointer;
    white-space: nowrap;
    text-decoration: none;
    transition: color 0.2s, border-color 0.2s;
  }
  .nav-tab:hover { color: var(--hgp-yellow); }
  .nav-tab.active { color: var(--hgp-yellow); border-bottom-color: var(--hgp-yellow); }
  .nav-tab .req-letter {
    display: inline-block;
    width: 20px;
    height: 20px;
    background: var(--hgp-yellow);
    color: var(--hgp-black);
    border-radius: 3px;
    font-size: 0.75rem;
    font-weight: 900;
    text-align: center;
    line-height: 20px;
    margin-right: 5px;
    vertical-align: middle;
  }

  /* ── MAIN CONTENT ── */
  main {
    max-width: 1200px;
    margin: 0 auto;
    padding: 40px 32px 80px;
  }

  /* ── REQUIREMENT SECTIONS ── */
  .req-section {
    margin-bottom: 60px;
    scroll-margin-top: 140px;
  }
  .req-header {
    display: flex;
    align-items: center;
    gap: 18px;
    margin-bottom: 28px;
    padding-bottom: 16px;
    border-bottom: 2px solid #2A2A2A;
  }
  .req-letter-badge {
    font-family: 'DINNextLT', sans-serif;
    font-weight: 900;
    font-size: 2.2rem;
    width: 64px;
    height: 64px;
    background: var(--hgp-yellow);
    color: var(--hgp-black);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    line-height: 1;
  }
  .req-title-area h2 {
    font-family: 'DINNextLT', sans-serif;
    font-weight: 900;
    font-size: 1.9rem;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    line-height: 1;
    color: var(--hgp-white);
  }
  .req-title-area p {
    font-size: 0.85rem;
    color: #888;
    margin-top: 4px;
  }
  .req-title-area p strong { color: var(--hgp-yellow); }

  /* ── SUBJECT TABS ── */
  .subject-tabs {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 22px;
  }
  .subj-tab {
    font-family: 'DINNextLT', sans-serif;
    font-weight: 700;
    font-size: 0.8rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 7px 14px;
    border-radius: 4px;
    border: 1.5px solid #333;
    background: #1C1C1C;
    color: #AAA;
    cursor: pointer;
    transition: all 0.15s;
  }
  .subj-tab:hover { border-color: var(--hgp-yellow); color: var(--hgp-yellow); }
  .subj-tab.active { background: var(--hgp-yellow); color: var(--hgp-black); border-color: var(--hgp-yellow); }

  /* ── SUBJECT PANEL ── */
  .subject-panel { display: none; }
  .subject-panel.active { display: block; }

  .subject-panel-header {
    font-family: 'DINNextLT', sans-serif;
    font-weight: 800;
    font-size: 1.3rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--hgp-yellow);
    margin-bottom: 18px;
  }

  /* ── RESOURCE GRID ── */
  .resource-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 14px;
    margin-bottom: 24px;
  }

  .resource-card {
    background: #1A1A1A;
    border: 1px solid #2C2C2C;
    border-radius: 8px;
    padding: 16px;
    transition: border-color 0.2s, transform 0.15s;
    position: relative;
  }
  .resource-card:hover {
    border-color: rgba(255,224,0,0.4);
    transform: translateY(-2px);
  }
  .card-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 8px;
  }
  .card-title {
    font-family: 'Gotham', sans-serif;
    font-weight: 700;
    font-size: 0.95rem;
    color: var(--hgp-white);
    line-height: 1.3;
    flex: 1;
    margin-right: 8px;
  }
  .card-badges {
    display: flex;
    flex-direction: column;
    gap: 3px;
    flex-shrink: 0;
  }
  .card-desc {
    font-size: 0.82rem;
    color: #999;
    line-height: 1.5;
    margin-bottom: 12px;
  }
  .card-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: 'DINNextLT', sans-serif;
    font-weight: 700;
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--hgp-yellow);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color 0.2s;
  }
  .card-link:hover { border-bottom-color: var(--hgp-yellow); }
  .card-link svg { width: 12px; height: 12px; }

  /* ── CATEGORY HEADERS inside panels ── */
  .category-header {
    font-family: 'DINNextLT', sans-serif;
    font-weight: 800;
    font-size: 0.75rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #555;
    margin: 22px 0 10px;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .category-header::after {
    content: '';
    flex: 1;
    height: 1px;
    background: #2A2A2A;
  }

  /* ── FOOTER ── */
  footer {
    background: #0A0A0A;
    border-top: 3px solid var(--hgp-yellow);
    padding: 32px;
    text-align: center;
  }
  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
  }
  footer p {
    font-size: 0.8rem;
    color: #555;
    margin-top: 8px;
  }
  footer strong { color: var(--hgp-yellow); }

  /* ── RESPONSIVE ── */
  @media (max-width: 700px) {
    .header-inner { padding: 12px 16px; }
    main { padding: 24px 16px 60px; }
    .req-letter-badge { width: 48px; height: 48px; font-size: 1.7rem; }
    .hero { padding: 40px 16px 36px; }
    .nav-section { padding: 0 16px; }
    .legend-bar { padding: 12px 16px; }
    .header-title { display: none; }
  }



/* ─── COLLEGE PAGE: Subtitle text colors by background ─── */
/* Dark sections (sec-black #000, sec-gray #1A1A1A) → white/yellow */
#page-college .sec-black .sec-title,
#page-college .sec-gray .sec-title,
#page-college .sec-black h2,
#page-college .sec-gray h2,
#page-college .sec-black h3,
#page-college .sec-gray h3,
#page-college .sec-black .sec-head-desc,
#page-college .sec-gray .sec-head-desc {
  color: #fff;
}
/* Eyebrows always electric yellow */
#page-college .sec-black .sec-eyebrow,
#page-college .sec-gray .sec-eyebrow {
  color: #ffe000;
}
/* Hero left (black bg) → white */
#page-college .hero-l .hero-title,
#page-college .hero-l .hero-sub,
#page-college .hero-l .hero-badge,
#page-college .hero-l .hero-stats,
#page-college .hero-l .stat-l {
  color: #fff;
}
/* Hero right (yellow bg) → black text — intentional, DO NOT override */
#page-college .hero-r .hero-r-sub {
  color: rgba(0,0,0,0.7);
}
/* General fallback for any heading on a dark bg in this page */
#page-college .sec-title { color: #fff; }
#page-college .sec-eyebrow { color: #ffe000; }
#page-college .sec-head-desc { color: rgba(255,255,255,0.65); }

/* === COLLEGE === */

@font-face {
  font-family: 'DINNext';
  src: url('data:font/otf;base64,') format('opentype');
  font-weight: 700;
}
@font-face {
  font-family: 'DINNext';
  src: url('data:font/otf;base64,') format('opentype');
  font-weight: 300;
}
:root {
  --yellow: #FFE000; --black: #000; --white: #fff;
  --dark: #0A0A0A; --dark2: #111; --g1: #1A1A1A; --g2: #252525; --g3: #333;
  --g9: #ffe000; --g10: #0a0a0a; --g11: #ffe000; --g12: #0a0a0a;
  --green: #22C55E; --red: #EF4444;
  --DIN: 'DINNext','Arial Narrow',Arial,sans-serif;
}
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{background:var(--dark);color:#fff;font-family:var(--DIN);font-weight:300;overflow-x:hidden;font-size:17px;}
a{text-decoration:none;color:inherit;}

/* NAV */
#nav{position:sticky;top:0;z-index:999;background:#000;border-bottom:3px solid var(--yellow);display:flex;align-items:center;justify-content:space-between;padding:0 2rem;height:60px;}
#nav img{height:36px;}
.nav-links{display:flex;list-style:none;}
.nav-links a{color:rgba(255,255,255,.6);font-family:var(--DIN);font-weight:700;font-size:.78rem;letter-spacing:.1em;text-transform:uppercase;padding:0 1rem;height:60px;line-height:60px;display:block;border-left:1px solid rgba(255,255,255,.08);transition:all .18s;}
.nav-links a:hover{background:var(--yellow);color:#000;}

/* HERO */
#hero{display:grid;grid-template-columns:58% 42%;min-height:100vh;background:#000;}
.hero-l{padding:5rem 4rem;display:flex;flex-direction:column;justify-content:center;}
.hero-badge{display:inline-flex;align-items:center;background:var(--yellow);color:#000;font-weight:700;font-size:.78rem;letter-spacing:.18em;text-transform:uppercase;padding:.4rem .9rem;margin-bottom:2rem;width:fit-content;}
.hero-title{font-size:clamp(4rem,6.5vw,7.5rem);font-weight:700;line-height:.88;text-transform:uppercase;letter-spacing:-.01em;margin-bottom:1.5rem;}
.hero-title em{color:var(--yellow);font-style:normal;display:block;}
.hero-sub{font-size:1.15rem;font-weight:300;color:rgba(255,255,255,.55);line-height:1.7;max-width:500px;margin-bottom:2.5rem;}
.hero-btns{display:flex;gap:1rem;flex-wrap:wrap;}
.btn-y{background:var(--yellow);color:#000;border:none;cursor:pointer;font-family:var(--DIN);font-weight:700;font-size:.95rem;letter-spacing:.12em;text-transform:uppercase;padding:1rem 2rem;transition:all .18s;display:inline-block;}
.btn-y:hover{background:#fff;}
.btn-o{background:transparent;color:#fff;border:2px solid rgba(255,255,255,.25);cursor:pointer;font-family:var(--DIN);font-weight:700;font-size:.95rem;letter-spacing:.12em;text-transform:uppercase;padding:1rem 2rem;transition:all .18s;display:inline-block;}
.btn-o:hover{border-color:var(--yellow);color:var(--yellow);}
.hero-stats{display:grid;grid-template-columns:repeat(3,1fr);margin-top:3rem;border:1px solid rgba(255,255,255,.1);}
.stat{padding:1.3rem;text-align:center;border-right:1px solid rgba(255,255,255,.1);}
.stat:last-child{border-right:none;}
.stat-n{font-size:2.4rem;font-weight:700;color:var(--yellow);line-height:1;}
.stat-l{font-size:.68rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:rgba(255,255,255,.4);margin-top:.3rem;}
.hero-r{background:var(--yellow);display:flex;flex-direction:column;align-items:center;justify-content:center;padding:4rem 3rem;position:relative;overflow:hidden;}
.hero-r::before{content:'';position:absolute;width:600px;height:600px;border-radius:50%;background:rgba(0,0,0,.06);top:-200px;right:-200px;}
/* Logo on yellow bg — no background-color override needed; PNG has transparent bg */
.hero-r img{width:82%;max-width:350px;position:relative;z-index:1;}
.hero-r-sub{position:relative;z-index:1;margin-top:2rem;text-align:center;font-weight:700;font-size:1rem;color:rgba(0,0,0,.55);letter-spacing:.08em;text-transform:uppercase;line-height:1.5;}

/* SECTIONS */
.sec{padding:5rem 0;}
.sec-dark{background:var(--dark);}
.sec-black{background:#000;}
.sec-gray{background:var(--g1);}
.wrap{max-width:1340px;margin:0 auto;padding:0 3rem;}
.sec-eyebrow{font-size:.78rem;font-weight:700;letter-spacing:.28em;text-transform:uppercase;color:var(--yellow);margin-bottom:.7rem;}
.sec-title{font-size:clamp(2.4rem,3.8vw,4.2rem);font-weight:700;text-transform:uppercase;line-height:.92;}
.sec-head-row{display:flex;align-items:flex-end;justify-content:space-between;gap:2rem;padding-bottom:1.5rem;border-bottom:3px solid var(--yellow);margin-bottom:3rem;}
.sec-head-desc{max-width:500px;font-size:1.05rem;color:rgba(255,255,255,.5);line-height:1.65;}

/* GRADE TABS */
.grade-tabs{display:grid;grid-template-columns:repeat(4,1fr);gap:2px;margin-bottom:0;}
.gtab{background:var(--g2);border:none;cursor:pointer;padding:1.5rem 1rem;font-family:var(--DIN);font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:rgba(255,255,255,.35);transition:all .22s;text-align:center;border-bottom:4px solid transparent;}
.gtab .gn{display:block;font-size:2.8rem;line-height:1;margin-bottom:.28rem;}
.gtab .gl{font-size:.78rem;letter-spacing:.1em;}
.gtab:hover{background:var(--g3);color:rgba(255,255,255,.7);}
.gtab.active-9{background:var(--g9);color:#000;}
.gtab.active-10{background:var(--g10);color:#ffe000;border-bottom:4px solid #ffe000;}
.gtab.active-11{background:var(--g11);color:#000;}
.gtab.active-12{background:var(--g12);color:#ffe000;border-bottom:4px solid #ffe000;}
.gpanel{display:none;}
.gpanel.active{display:block;animation:fadeUp .35s ease;}
@keyframes fadeUp{from{opacity:0;transform:translateY(14px)}to{opacity:1;transform:none}}
.gpanel-header{display:flex;align-items:center;gap:2rem;padding:2rem 2.5rem;margin-bottom:2rem;}
.gph-9{background:var(--g9);color:#000;}
.gph-10{background:var(--g10);color:#ffe000;border:2px solid #ffe000;}
.gph-11{background:var(--g11);color:#000;}
.gph-12{background:var(--g12);color:#ffe000;border:2px solid #ffe000;}
.gph-num{font-size:5rem;font-weight:700;line-height:1;}
.gph-info h3{font-size:1.8rem;font-weight:700;text-transform:uppercase;}
.gph-info p{font-size:1rem;opacity:.7;margin-top:.4rem;font-weight:300;}
.goals-row{display:flex;align-items:flex-start;gap:1.5rem;background:#000;padding:1.3rem 2.5rem;margin-bottom:2rem;flex-wrap:wrap;}
.goals-label{font-size:.7rem;font-weight:700;letter-spacing:.18em;text-transform:uppercase;color:var(--yellow);min-width:80px;padding-top:.35rem;flex-shrink:0;}
.goals-pills{display:flex;gap:.5rem;flex-wrap:wrap;}
.gpill{background:var(--g2);border:1px solid rgba(255,255,255,.1);padding:.35rem .85rem;font-size:.78rem;font-weight:700;letter-spacing:.05em;text-transform:uppercase;color:rgba(255,255,255,.75);}
.seasons{display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem;margin-bottom:2rem;}
.season-card{background:var(--g2);border-top:4px solid var(--yellow);padding:1.5rem;}
.season-title{font-size:1.15rem;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:var(--yellow);margin-bottom:1rem;display:flex;align-items:center;gap:.5rem;}
.season-items{list-style:none;}
.season-items li{padding:.5rem 0 .5rem 1.1rem;border-bottom:1px solid rgba(255,255,255,.06);font-size:.92rem;color:rgba(255,255,255,.78);line-height:1.5;position:relative;}
.season-items li::before{content:'→';position:absolute;left:0;color:var(--yellow);font-size:.75rem;top:.6rem;}
.season-items li:last-child{border-bottom:none;}
.dodont{display:grid;grid-template-columns:1fr 1fr;gap:1.5rem;}
.do-card{background:rgba(34,197,94,.08);border-left:4px solid var(--green);padding:1.5rem;}
.dont-card{background:rgba(239,68,68,.08);border-left:4px solid var(--red);padding:1.5rem;}
.do-card h4{color:var(--green);font-weight:700;font-size:1rem;text-transform:uppercase;letter-spacing:.1em;margin-bottom:1rem;}
.dont-card h4{color:var(--red);font-weight:700;font-size:1rem;text-transform:uppercase;letter-spacing:.1em;margin-bottom:1rem;}
.do-card ul,.dont-card ul{list-style:none;}
.do-card li,.dont-card li{padding:.4rem 0 .4rem 1.3rem;font-size:.92rem;color:rgba(255,255,255,.78);line-height:1.45;position:relative;}
.do-card li::before{content:'✓';position:absolute;left:0;color:var(--green);}
.dont-card li::before{content:'✗';position:absolute;left:0;color:var(--red);}

/* A-G */
.ag-grid{display:grid;grid-template-columns:repeat(4,1fr);border:1px solid var(--g3);}
.ag-item{padding:1.7rem 1.4rem;border-right:1px solid var(--g3);border-bottom:1px solid var(--g3);transition:background .18s;}
.ag-item:hover{background:var(--g2);}
.ag-badge{width:48px;height:48px;background:var(--yellow);color:#000;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:1.6rem;margin-bottom:1rem;}
.ag-sub{font-weight:700;font-size:1rem;text-transform:uppercase;letter-spacing:.04em;margin-bottom:.35rem;}
.ag-yrs{font-size:.78rem;font-weight:700;color:var(--yellow);letter-spacing:.07em;margin-bottom:.45rem;}
.ag-detail{font-size:.83rem;color:rgba(255,255,255,.5);line-height:1.5;}
.ag-note{background:var(--yellow);color:#000;padding:1.4rem 2rem;margin-top:2rem;display:flex;gap:1rem;align-items:flex-start;}
.ag-note-icon{font-size:1.5rem;flex-shrink:0;}
.ag-note-text{font-size:.95rem;font-weight:700;line-height:1.55;}

/* PATHWAY */
.interest-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:.9rem;margin-bottom:2rem;}
.ibtn{background:var(--g2);border:2px solid transparent;padding:1.5rem .85rem;text-align:center;cursor:pointer;font-family:var(--DIN);font-weight:700;font-size:.85rem;letter-spacing:.08em;text-transform:uppercase;color:rgba(255,255,255,.5);transition:all .22s;display:flex;flex-direction:column;align-items:center;gap:.65rem;}
.ibtn .ii{font-size:2rem;}
.ibtn:hover{border-color:var(--yellow);color:var(--yellow);background:rgba(255,224,0,.05);}
.ibtn.sel{background:var(--yellow);color:#000;border-color:var(--yellow);}
.path-results{display:none;}
.path-results.show{display:block;animation:fadeUp .4s ease;}
.path-match-header{background:var(--yellow);color:#000;padding:1.5rem 2rem;display:flex;align-items:center;gap:1rem;margin-bottom:2rem;}
.path-match-header h3{font-size:1.6rem;font-weight:700;text-transform:uppercase;}
.path-match-header p{font-size:.95rem;margin-top:.2rem;}
.path-cards{display:grid;grid-template-columns:repeat(3,1fr);gap:1.3rem;}
.path-card{background:var(--g1);border-top:4px solid var(--yellow);padding:1.7rem;}
.pc-cat{font-size:.7rem;font-weight:700;letter-spacing:.18em;text-transform:uppercase;color:var(--yellow);margin-bottom:.55rem;}
.pc-title{font-size:1.12rem;font-weight:700;text-transform:uppercase;margin-bottom:.65rem;}
.pc-desc{font-size:.85rem;color:rgba(255,255,255,.55);line-height:1.55;margin-bottom:.85rem;}
.pc-salary{font-size:.78rem;color:var(--green);font-weight:700;letter-spacing:.08em;}
.pc-schools{font-size:.72rem;color:rgba(255,255,255,.35);margin-top:.5rem;}

/* COLLEGE MATCH */
.match-form{background:#000;padding:2.2rem;margin-bottom:2rem;}
.form-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.3rem;margin-bottom:2rem;}
.fg{display:flex;flex-direction:column;gap:.45rem;}
.fg label{font-size:.72rem;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:var(--yellow);}
.fg select{background:var(--g2);border:2px solid var(--g3);color:#fff;font-family:var(--DIN);font-size:.95rem;padding:.8rem 1rem;outline:none;transition:border-color .18s;font-weight:300;-webkit-appearance:none;cursor:pointer;}
.fg select:focus{border-color:var(--yellow);}
.fg select option{background:var(--g2);}
.priority-label{font-size:.72rem;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:rgba(255,255,255,.4);margin-bottom:1rem;}
.pgrid{display:grid;grid-template-columns:repeat(4,1fr);gap:.7rem;margin-bottom:2rem;}
.pbtn{background:var(--g2);border:2px solid transparent;padding:.95rem .8rem;font-family:var(--DIN);font-weight:700;font-size:.75rem;letter-spacing:.06em;text-transform:uppercase;color:rgba(255,255,255,.5);cursor:pointer;transition:all .2s;text-align:center;}
.pbtn .pi{display:block;font-size:1.4rem;margin-bottom:.4rem;}
.pbtn:hover{border-color:var(--yellow);color:var(--yellow);}
.pbtn.sel{background:var(--yellow);color:#000;border-color:var(--yellow);}
.btn-match{background:var(--yellow);color:#000;border:none;padding:1.1rem 2.5rem;font-family:var(--DIN);font-weight:700;font-size:1rem;letter-spacing:.12em;text-transform:uppercase;cursor:pointer;transition:all .2s;width:100%;}
.btn-match:hover{background:#fff;}
.match-results{display:none;}
.match-results.show{display:block;animation:fadeUp .4s ease;}
.match-head{border-bottom:3px solid var(--yellow);padding-bottom:1rem;margin-bottom:2rem;display:flex;align-items:baseline;gap:1rem;}
.match-head h3{font-size:2rem;font-weight:700;text-transform:uppercase;}
.match-head p{font-size:.9rem;color:rgba(255,255,255,.4);}
.ccards{display:grid;grid-template-columns:repeat(3,1fr);gap:1.3rem;}
.ccard{background:var(--dark2);border:1px solid var(--g3);overflow:hidden;transition:border-color .2s;position:relative;}
.ccard:hover{border-color:var(--yellow);}
.ccard-top{padding:1.4rem;border-bottom:1px solid var(--g3);}
.cc-score{position:absolute;top:1rem;right:1rem;background:var(--yellow);color:#000;font-weight:700;font-size:.92rem;padding:.18rem .55rem;}
.cc-sys{font-size:.65rem;font-weight:700;letter-spacing:.18em;text-transform:uppercase;color:rgba(255,255,255,.3);margin-bottom:.38rem;}
.cc-name{font-size:1.25rem;font-weight:700;text-transform:uppercase;padding-right:3.5rem;margin-bottom:.22rem;}
.cc-loc{font-size:.78rem;color:rgba(255,255,255,.4);}
.ccard-body{padding:1.2rem 1.4rem;}
.cc-tags{display:flex;gap:.38rem;flex-wrap:wrap;margin-bottom:1rem;}
.cctag{font-size:.65rem;font-weight:700;letter-spacing:.09em;text-transform:uppercase;padding:.18rem .48rem;border:1px solid rgba(255,255,255,.18);color:rgba(255,255,255,.5);}
.cctag.g{border-color:var(--green);color:var(--green);}
.cctag.b{border-color:#3b82f6;color:#3b82f6;}
.cctag.y{border-color:var(--yellow);color:var(--yellow);}
.cc-facts{display:grid;grid-template-columns:1fr 1fr;gap:.5rem;}
.ccf-l{font-size:.63rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:rgba(255,255,255,.28);}
.ccf-v{font-size:.88rem;font-weight:700;color:rgba(255,255,255,.85);}

/* FINANCIAL AID */
.aid-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.3rem;}
.aid-card{background:var(--g2);padding:2rem;border-bottom:4px solid var(--yellow);}
.aid-icon{font-size:2rem;margin-bottom:.9rem;}
.aid-name{font-size:1.08rem;font-weight:700;text-transform:uppercase;letter-spacing:.05em;margin-bottom:.75rem;}
.aid-desc{font-size:.85rem;color:rgba(255,255,255,.55);line-height:1.6;margin-bottom:1rem;}
.aid-amt{font-size:1.4rem;font-weight:700;color:var(--yellow);}
.aid-amt-l{font-size:.68rem;color:rgba(255,255,255,.35);letter-spacing:.05em;}
.aid-dead{font-size:.75rem;font-weight:700;color:var(--red);letter-spacing:.08em;text-transform:uppercase;margin-top:.7rem;}

/* GLOSSARY */
.gloss-search{background:var(--g2);border:2px solid var(--g3);display:flex;align-items:center;gap:.9rem;padding:0 1.3rem;margin-bottom:2rem;}
.gloss-search span{color:var(--yellow);font-size:1.2rem;}
.gloss-search input{background:transparent;border:none;outline:none;color:#fff;font-family:var(--DIN);font-size:1.05rem;font-weight:300;padding:1.05rem 0;flex:1;letter-spacing:.04em;}
.gloss-search input::placeholder{color:rgba(255,255,255,.3);}
.gloss-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--g3);}
.gi{background:var(--g1);padding:1.4rem;transition:background .18s;}
.gi:hover{background:var(--g2);}
.gi-term{font-weight:700;font-size:.85rem;text-transform:uppercase;letter-spacing:.1em;color:var(--yellow);margin-bottom:.45rem;}
.gi-def{font-size:.83rem;color:rgba(255,255,255,.55);line-height:1.55;}

/* FOOTER */
footer{background:#000;border-top:3px solid var(--yellow);padding:2.5rem 3rem;display:flex;align-items:center;justify-content:space-between;gap:2rem;flex-wrap:wrap;}
footer img{height:42px;}
.foot-text{font-size:.78rem;color:rgba(255,255,255,.35);line-height:1.65;}
.foot-text strong{color:var(--yellow);}

/* RESPONSIVE */
@media(max-width:1100px){
  #hero{grid-template-columns:1fr;}
  .hero-r{min-height:380px;}
  .ag-grid{grid-template-columns:repeat(2,1fr);}
  .ccards{grid-template-columns:repeat(2,1fr);}
  .path-cards{grid-template-columns:repeat(2,1fr);}
}
@media(max-width:768px){
  .wrap{padding:0 1.3rem;}
  .hero-l{padding:3rem 1.3rem;}
  .hero-title{font-size:3.5rem;}
  .grade-tabs{grid-template-columns:repeat(2,1fr);}
  .seasons{grid-template-columns:1fr;}
  .dodont{grid-template-columns:1fr;}
  .gloss-grid{grid-template-columns:1fr;}
  .ccards{grid-template-columns:1fr;}
  .path-cards{grid-template-columns:1fr;}
  .interest-grid{grid-template-columns:repeat(2,1fr);}
  .form-grid{grid-template-columns:1fr;}
  .pgrid{grid-template-columns:repeat(2,1fr);}
  .aid-grid{grid-template-columns:1fr;}
  .nav-links{display:none;}
  .sec-head-row{flex-direction:column;align-items:flex-start;}
}


/* === TUTORING CSS: moved inline to panel === */
/* === SMART STYLES: scoped to #page-smart === */
/* === TIME === */

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --gold: #FFE000;
    --gold-pale: #FFE000;
    --gold-deep: #FFE000;
    --white: #FFFFFF;
    --off-white: #F8F7F3;
    --mid: #555;
    --border: rgba(0,0,0,0.09);
    --green: #1D8A4E;
    --green-light: #E8F7EE;
    --blue: #1B5FA8;
    --blue-light: #E8F1FB;
    --purple: #6B3FA0;
    --purple-light: #F2EBF9;
    --red: #C0392B;
    --red-light: #FDECEB;
    --teal: #0F7A6E;
    --teal-light: #E4F4F2;
  }

  html { scroll-behavior: smooth; }
  /* body rule removed - pages use their own background */

  /* ── TICKER STRIP ── */
  .ticker-wrap {
    background: var(--gold);
    overflow: hidden;
    white-space: nowrap;
    padding: 7px 0;
  }
  .ticker-inner {
    display: inline-block;
    animation: ticker 28s linear infinite;
  }
  .ticker-inner span {
    font-family: 'DINNextLT', monospace;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--black);
    padding: 0 40px;
  }
  @keyframes ticker { from { transform: translateX(0); } to { transform: translateX(-50%); } }

  /* ── NAV ── */
  nav {
    background: var(--black);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 2.5rem;
  }
  .nav-logo {
    display: flex;
    align-items: center;
    gap: 12px;
    text-decoration: none;
  }
  .nav-logo-box {
    background: var(--gold);
    color: var(--black);
    font-family: 'Gotham', sans-serif;
    font-size: 13px;
    letter-spacing: 1px;
    padding: 4px 10px;
    border-radius: 4px;
  }
  .nav-title {
    color: rgba(255,255,255,0.5);
    font-size: 12px;
    letter-spacing: 1px;
    text-transform: uppercase;
  }
  .nav-pill {
    background: rgba(245,166,35,0.15);
    color: var(--gold);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 1px;
    text-transform: uppercase;
    padding: 5px 14px;
    border-radius: 20px;
    border: 0.5px solid rgba(245,166,35,0.3);
  }

  /* ── HERO ── */
  .hero {
    background: var(--black);
    padding: 4rem 2.5rem 3.5rem;
    position: relative;
    overflow: hidden;
  }
  .hero-grid-bg {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(245,166,35,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(245,166,35,0.04) 1px, transparent 1px);
    background-size: 40px 40px;
  }
  .hero-num {
    font-family: 'Gotham', sans-serif;
    font-size: clamp(120px, 20vw, 220px);
    line-height: 0.85;
    color: rgba(245,166,35,0.06);
    position: absolute;
    right: -20px;
    bottom: -20px;
    letter-spacing: -5px;
    pointer-events: none;
    user-select: none;
  }
  .hero-inner { position: relative; z-index: 1; max-width: 680px; }
  .hero-eyebrow {
    font-family: 'DINNextLT', monospace;
    font-size: 11px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 1rem;
  }
  .hero h1 {
    font-family: 'Gotham', sans-serif;
    font-size: clamp(52px, 8vw, 90px);
    line-height: 0.93;
    color: var(--off-white);
    letter-spacing: 1px;
    margin-bottom: 1.5rem;
  }
  .hero h1 em {
    color: var(--gold);
    font-style: normal;
    display: block;
  }
  .hero-desc {
    font-size: 16px;
    color: rgba(255,255,255,0.6);
    line-height: 1.7;
    max-width: 520px;
    margin-bottom: 2rem;
  }
  .hero-stats {
    display: flex;
    gap: 2rem;
    flex-wrap: wrap;
  }
  .hero-stat-val {
    font-family: 'Gotham', sans-serif;
    font-size: 36px;
    color: var(--gold);
    line-height: 1;
  }
  .hero-stat-label {
    font-size: 11px;
    color: rgba(255,255,255,0.4);
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-top: 2px;
  }

  /* ── MAIN CONTENT ── */
  main { max-width: 960px; margin: 0 auto; padding: 3rem 2rem 5rem; }

  /* ── SECTION HEADERS ── */
  .sec-head {
    display: flex;
    align-items: baseline;
    gap: 14px;
    margin-bottom: 1.5rem;
  }
  .sec-num {
    font-family: 'Gotham', sans-serif;
    font-size: 48px;
    color: rgba(0,0,0,0.08);
    line-height: 1;
    flex-shrink: 0;
  }
  .sec-label-wrap {}
  .sec-label {
    font-family: 'DINNextLT', monospace;
    font-size: 10px;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: var(--gold-deep);
    display: block;
    margin-bottom: 2px;
  }
  .sec-title {
    font-family: 'Gotham', sans-serif;
    font-size: 28px;
    letter-spacing: 0.5px;
    color: var(--black);
    line-height: 1;
  }

  /* ── DIVIDER ── */
  .divider {
    height: 1px;
    background: var(--border);
    margin: 3rem 0;
  }

  /* ── KEY TERMS ── */
  .terms-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 10px;
    margin-bottom: 3rem;
  }
  .term-card {
    background: var(--black);
    border-radius: 12px;
    padding: 1.25rem;
    position: relative;
    overflow: hidden;
  }
  .term-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: 3px; height: 100%;
    background: var(--gold);
    border-radius: 3px 0 0 3px;
  }
  .term-word {
    font-family: 'Gotham', sans-serif;
    font-size: 22px;
    color: var(--gold);
    letter-spacing: 0.5px;
    margin-bottom: 4px;
  }
  .term-def {
    font-size: 12px;
    color: rgba(255,255,255,0.55);
    line-height: 1.5;
  }

  /* ── TIP CARDS ── */
  .tips-stack { display: flex; flex-direction: column; gap: 14px; }

  .tip-card {
    background: white;
    border: 0.5px solid var(--border);
    border-radius: 16px;
    padding: 1.5rem 1.75rem;
    display: grid;
    grid-template-columns: 56px 1fr;
    gap: 1.25rem;
    align-items: start;
    transition: box-shadow 0.2s, transform 0.2s;
    position: relative;
    overflow: hidden;
  }
  .tip-card:hover {
    box-shadow: 0 8px 32px rgba(0,0,0,0.07);
    transform: translateY(-1px);
  }
  .tip-card::after {
    content: '';
    position: absolute;
    top: 0; right: 0;
    width: 4px; height: 100%;
    border-radius: 0 16px 16px 0;
  }
  .tip-card.c-green::after { background: var(--green); }
  .tip-card.c-blue::after  { background: var(--blue); }
  .tip-card.c-purple::after{ background: var(--purple); }
  .tip-card.c-red::after   { background: var(--red); }
  .tip-card.c-teal::after  { background: var(--teal); }
  .tip-card.c-gold::after  { background: var(--gold); }

  .tip-icon-wrap {
    width: 56px; height: 56px;
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 24px;
    flex-shrink: 0;
  }
  .c-green .tip-icon-wrap  { background: var(--green-light); }
  .c-blue .tip-icon-wrap   { background: var(--blue-light); }
  .c-purple .tip-icon-wrap { background: var(--purple-light); }
  .c-red .tip-icon-wrap    { background: var(--red-light); }
  .c-teal .tip-icon-wrap   { background: var(--teal-light); }
  .c-gold .tip-icon-wrap   { background: var(--gold-pale); }

  .tip-body {}
  .tip-num-badge {
    font-family: 'DINNextLT', monospace;
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 1px;
    color: var(--mid);
    margin-bottom: 4px;
  }
  .tip-title {
    font-size: 17px;
    font-weight: 600;
    line-height: 1.25;
    margin-bottom: 6px;
  }
  .c-green .tip-title  { color: var(--green); }
  .c-blue .tip-title   { color: var(--blue); }
  .c-purple .tip-title { color: var(--purple); }
  .c-red .tip-title    { color: var(--red); }
  .c-teal .tip-title   { color: var(--teal); }
  .c-gold .tip-title   { color: var(--gold-deep); }

  .tip-desc {
    font-size: 14px;
    color: var(--mid);
    line-height: 1.65;
    margin-bottom: 10px;
  }
  .tip-action {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    font-weight: 600;
    padding: 5px 12px;
    border-radius: 20px;
    letter-spacing: 0.2px;
  }
  .c-green .tip-action  { background: var(--green-light);  color: var(--green); }
  .c-blue .tip-action   { background: var(--blue-light);   color: var(--blue); }
  .c-purple .tip-action { background: var(--purple-light); color: var(--purple); }
  .c-red .tip-action    { background: var(--red-light);    color: var(--red); }
  .c-teal .tip-action   { background: var(--teal-light);   color: var(--teal); }
  .c-gold .tip-action   { background: var(--gold-pale);    color: var(--gold-deep); }

  /* ── YOUR HGP SCHEDULE BOX ── */
  .schedule-box {
    background: var(--black);
    border-radius: 16px;
    padding: 1.75rem;
    margin-bottom: 3rem;
  }
  .sb-header {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 1.25rem;
  }
  .sb-badge {
    background: var(--gold);
    color: var(--black);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    padding: 3px 10px;
    border-radius: 4px;
  }
  .sb-title {
    font-family: 'Gotham', sans-serif;
    font-size: 22px;
    color: white;
    letter-spacing: 0.5px;
  }
  .sb-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 10px;
  }
  .sb-item {
    border: 0.5px solid rgba(245,166,35,0.2);
    border-radius: 10px;
    padding: 0.9rem 1rem;
  }
  .sb-day {
    font-family: 'DINNextLT', monospace;
    font-size: 10px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 4px;
  }
  .sb-time {
    font-size: 14px;
    font-weight: 600;
    color: white;
    margin-bottom: 2px;
  }
  .sb-note {
    font-size: 11px;
    color: rgba(255,255,255,0.4);
  }

  /* ── BALANCE SECTION ── */
  .balance-strip {
    background: var(--gold);
    border-radius: 16px;
    padding: 1.75rem;
    margin-bottom: 3rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    align-items: center;
  }
  .balance-left {}
  .balance-quote {
    font-family: 'Gotham', sans-serif;
    font-size: 30px;
    color: var(--black);
    line-height: 1.1;
    margin-bottom: 0.5rem;
  }
  .balance-sub {
    font-size: 13px;
    color: rgba(0,0,0,0.6);
    line-height: 1.6;
  }
  .balance-right {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .bal-row {
    background: rgba(0,0,0,0.08);
    border-radius: 8px;
    padding: 8px 12px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .bal-label { font-size: 13px; font-weight: 600; color: var(--black); }
  .bal-val {
    font-family: 'DINNextLT', monospace;
    font-size: 11px;
    color: rgba(0,0,0,0.5);
  }

  /* ── BLOCKING VISUAL ── */
  .blocking-grid {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 6px;
    margin-top: 1rem;
  }
  .bg-col { display: flex; flex-direction: column; gap: 5px; }
  .bg-day-label {
    font-family: 'DINNextLT', monospace;
    font-size: 9px;
    font-weight: 500;
    text-align: center;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--mid);
    padding-bottom: 4px;
  }
  .bg-block {
    border-radius: 8px;
    padding: 6px 4px;
    font-size: 8.5px;
    font-weight: 600;
    text-align: center;
    line-height: 1.3;
    min-height: 40px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .bg-block sub { font-size: 7.5px; font-weight: 400; opacity: 0.7; display: block; margin-top: 2px; }
  .bg-school  { background: var(--blue-light);   color: var(--blue); }
  .bg-hgp     { background: var(--black);         color: var(--gold); }
  .bg-sat     { background: var(--gold);           color: var(--black); }
  .bg-oh      { background: var(--purple-light);   color: var(--purple); }
  .bg-study   { background: var(--green-light);    color: var(--green); border: 0.5px dashed #82E0AA; }
  .bg-free    { background: #F4F4F2;               color: #CCC; }
  .bg-sleep   { background: #2C2C2C;              color: rgba(255,255,255,0.3); }

  /* ── CHECKLIST ── */
  .checklist {
    background: white;
    border: 0.5px solid var(--border);
    border-radius: 16px;
    padding: 1.5rem 1.75rem;
    margin-bottom: 3rem;
  }
  .checklist-title {
    font-family: 'Gotham', sans-serif;
    font-size: 22px;
    letter-spacing: 0.5px;
    margin-bottom: 1rem;
  }
  .cl-item {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 10px 0;
    border-bottom: 0.5px solid var(--border);
    font-size: 14px;
    color: var(--mid);
    line-height: 1.5;
  }
  .cl-item:last-child { border-bottom: none; }
  .cl-box {
    width: 20px; height: 20px;
    border-radius: 5px;
    border: 1.5px solid #CCC;
    flex-shrink: 0;
    margin-top: 1px;
  }
  .cl-text strong { color: var(--black); font-weight: 600; }

  /* ── REFLECTION ── */
  .reflection {
    background: var(--black);
    border-radius: 16px;
    padding: 1.75rem;
    margin-bottom: 3rem;
  }
  .ref-label {
    font-family: 'DINNextLT', monospace;
    font-size: 10px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 0.75rem;
  }
  .ref-q {
    font-size: 17px;
    font-weight: 500;
    color: white;
    line-height: 1.55;
    margin-bottom: 1.25rem;
  }
  .ref-lines {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .ref-line {
    height: 40px;
    border-bottom: 1px solid rgba(255,255,255,0.12);
    border-radius: 0;
  }

  /* ── FOOTER ── */
  footer {
    background: var(--black);
    padding: 1.5rem 2.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
  }
  .footer-brand {
    font-family: 'Gotham', sans-serif;
    font-size: 18px;
    color: var(--gold);
    letter-spacing: 1px;
  }
  .footer-note {
    font-size: 11px;
    color: rgba(255,255,255,0.35);
    letter-spacing: 0.5px;
  }

  /* ── ANIMATIONS ── */
  .fade-up {
    opacity: 0;
    transform: translateY(20px);
    animation: fadeUp 0.5s ease forwards;
  }
  @keyframes fadeUp {
    to { opacity: 1; transform: translateY(0); }
  }
  .tip-card { animation: fadeUp 0.4s ease both; }
  .tip-card:nth-child(1) { animation-delay: 0.05s; }
  .tip-card:nth-child(2) { animation-delay: 0.10s; }
  .tip-card:nth-child(3) { animation-delay: 0.15s; }
  .tip-card:nth-child(4) { animation-delay: 0.20s; }
  .tip-card:nth-child(5) { animation-delay: 0.25s; }
  .tip-card:nth-child(6) { animation-delay: 0.30s; }

  @media (max-width: 640px) {
    .hero { padding: 2.5rem 1.25rem 2rem; }
    main { padding: 2rem 1.25rem 4rem; }
    .terms-row { grid-template-columns: 1fr; }
    .tip-card { grid-template-columns: 1fr; }
    .tip-icon-wrap { display: none; }
    .balance-strip { grid-template-columns: 1fr; }
    .blocking-grid { grid-template-columns: repeat(4, 1fr); }
    nav { padding: 1rem 1.25rem; }
  }


/* === NEEDS === */

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --gold: #FFE000;
  --black: #0A0A0A;
  --near-black: #141414;
  --off-white: #F5F4F0;
  --white: #FFFFFF;
  --mid: #555;
  --light: #888;
  --border: #E0DFD8;
  --border-dark: rgba(255,255,255,0.08);
  --red: #C0392B;
  --red-light: #FDF2F1;
}

html { scroll-behavior: smooth; }
body {
  font-family: 'Gotham', sans-serif;
  background: var(--black);
  color: var(--white);
  min-height: 100vh;
}

/* TICKER */
.ticker-wrap {
  background: var(--gold);
  overflow: hidden;
  white-space: nowrap;
  padding: 7px 0;
}
.ticker-inner {
  display: inline-block;
  animation: ticker 28s linear infinite;
}
.ticker-inner span {
  font-family: 'DINNextLT', monospace;
  font-size: 9px;
  font-weight: 500;
  letter-spacing: 2.5px;
  text-transform: uppercase;
  color: var(--black);
  padding: 0 36px;
}
@keyframes ticker { from { transform: translateX(0); } to { transform: translateX(-50%); } }

/* NAV */
nav {
  background: var(--black);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 1.1rem 2.5rem;
  border-bottom: 1px solid var(--border-dark);
}
.nav-brand {
  display: flex;
  align-items: center;
  gap: 14px;
  text-decoration: none;
}
.nav-logo-box {
  background: var(--gold);
  color: var(--black);
  font-family: 'Gotham', sans-serif;
  font-size: 13px;
  letter-spacing: 1px;
  padding: 4px 10px;
  border-radius: 3px;
}
.nav-title {
  font-family: 'Gotham', sans-serif;
  font-size: 18px;
  letter-spacing: 1.5px;
  color: var(--white);
}
.nav-title span { color: var(--gold); }
.back-link {
  display: flex;
  align-items: center;
  gap: 8px;
  font-family: 'DINNextLT', monospace;
  font-size: 9px;
